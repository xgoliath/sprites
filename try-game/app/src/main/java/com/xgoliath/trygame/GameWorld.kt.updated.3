package com.xgoliath.trygame

import android.graphics.Canvas

class GameWorld(private val loader: SpriteLoader, private val soundManager: SoundManager) {
    val platforms = mutableListOf<Platform>()
    val enemies = mutableListOf<Enemy>()
    lateinit var player: Player
    lateinit var companion: Companion
    val particles = ParticleSystem()

    init {
        // simple level: ground + some platforms
        platforms.add(Platform(0f, 1100f, 2000f, 200f))
        platforms.add(Platform(400f, 900f, 300f, 40f))
        platforms.add(Platform(800f, 750f, 300f, 40f))

        // enemies
        enemies.add(Enemy(600f, 1000f, loader))
        enemies.add(Enemy(1000f, 1000f, loader))

        // will set player and companion later from GameSurfaceView
    }

    fun update(delta: Long) {
        player.update(delta)
        companion.update(delta)

        // collisions with platforms
        for (p in platforms) {
            if (player.collidesWith(p)) {
                player.landOn(p)
            }
            if (companion.collidesWith(p)) {
                companion.landOn(p)
            }
        }

        // update enemies
        val iterator = enemies.iterator()
        while (iterator.hasNext()) {
            val e = iterator.next()
            e.update(delta)

            // handle player attack collision
            if (player.isAttacking && player.attackHitboxIntersects(e)) {
                val prev = e.health
                e.takeDamage(1)
                if (e.health < prev) {
                    soundManager.playSfx("hit")
                    particles.spawn(e.x + e.width/2f, e.y + e.height/2f, 8)
                }
                if (e.isDead) {
                    soundManager.playSfx("death")
                    particles.spawn(e.x + e.width/2f, e.y + e.height/2f, 20)
                }
            }

            if (e.isDead) iterator.remove()
        }

        // companion attack
        if (companion.isAttacking) {
            for (e in enemies) {
                if (companion.attackHitboxIntersects(e)) {
                    val prev = e.health
                    e.takeDamage(1)
                    if (e.health < prev) {
                        soundManager.playSfx("hit")
                        particles.spawn(e.x + e.width/2f, e.y + e.height/2f, 8)
                    }
                    if (e.isDead) {
                        soundManager.playSfx("death")
                        particles.spawn(e.x + e.width/2f, e.y + e.height/2f, 20)
                    }
                }
            }
            companion.isAttacking = false
        }

        // update particles
        particles.update(delta)
    }

    fun draw(canvas: Canvas) {
        // draw platforms first
        for (p in platforms) p.draw(canvas)

        // draw entities sorted by vertical position (y + height) so lower entities appear in front
        val entities = mutableListOf<Entity>()
        entities.addAll(enemies)
        entities.add(companion)
        entities.add(player)
        entities.sortBy { it.y + it.height }
        for (ent in entities) ent.draw(canvas)

        // draw particles on top of entities
        particles.draw(canvas)
    }
}
